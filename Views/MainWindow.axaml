<Window
	x:Class="RospSqlGenerator.Views.MainWindow"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:converters="using:RospSqlGenerator.Converters"
	xmlns:models="using:RospSqlGenerator.Models"
	xmlns:vm="using:RospSqlGenerator.ViewModels"
	x:DataType="vm:MainWindowViewModel"
	Title="Генератор SQL обновления РОСП"
	WindowStartupLocation="CenterScreen"
	Width="1400"
	Height="820"
	MinWidth="1100"
	MinHeight="650">

	<Window.Resources>
		<converters:ConflictBackgroundBrushConverter x:Key="ConflictBackgroundBrushConverter" />
	</Window.Resources>

	<Window.Styles>
		<Style Selector="DataGridColumnHeader">
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontWeight" Value="Normal" />
			<Setter Property="MinHeight" Value="26" />
			<Setter Property="Padding" Value="6,0" />
		</Style>

		<Style Selector="DataGridCell">
			<Setter Property="FontSize" Value="12" />
			<Setter Property="Padding" Value="0" />
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="Auto,Auto,*,Auto"
		  Background="#F5F7FA">

		<!-- Верхняя панель -->
		<Border Grid.Row="0"
				Background="#FFFFFF"
				BorderBrush="#D8DEE8"
				BorderThickness="0,0,0,1"
				Padding="20,16">

			<Grid ColumnDefinitions="*,Auto">
				<StackPanel Spacing="4">
					<TextBlock Text="Генератор SQL обновления справочника РОСП"
							   FontSize="22"
							   FontWeight="SemiBold"
							   Foreground="#1F2937" />

					<TextBlock Text="Загрузите xlsx-файл, проверьте нормализованные записи и сохраните SQL-скрипт."
							   FontSize="13"
							   Foreground="#6B7280" />
				</StackPanel>

				<StackPanel Grid.Column="1"
							Orientation="Horizontal"
							Spacing="10"
							VerticalAlignment="Center">

					<Button Command="{Binding LoadCommand}"
							Content="Загрузить xlsx"
							VerticalContentAlignment="Center"
							HorizontalContentAlignment="Center"
							MinWidth="140"
							Height="36" />

					<Button Command="{Binding SaveCommand}"
							Content="Сохранить SQL"
							VerticalContentAlignment="Center"
							HorizontalContentAlignment="Center"
							MinWidth="140"
							Height="36" />
				</StackPanel>
			</Grid>
		</Border>

		<!-- Сводка и сообщения -->
		<Grid Grid.Row="1"
			  ColumnDefinitions="*,Auto"
			  Margin="20,16,20,4">

			<StackPanel Spacing="10">
				<Border Background="#FFFFFF"
						BorderBrush="#D8DEE8"
						BorderThickness="1"
						CornerRadius="10"
						Padding="14"
						Height="70">

					<Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*"
						  ColumnSpacing="20">

						<StackPanel>
							<TextBlock Text="Всего строк"
									   FontSize="12"
									   Foreground="#6B7280" />
							<TextBlock Text="{Binding TotalCount}"
									   FontSize="20"
									   FontWeight="SemiBold"
									   Foreground="#111827" />
						</StackPanel>

						<StackPanel Grid.Column="1">
							<TextBlock Text="Выбрано"
									   FontSize="12"
									   Foreground="#6B7280" />
							<TextBlock Text="{Binding SelectedCount}"
									   FontSize="20"
									   FontWeight="SemiBold"
									   Foreground="#111827" />
						</StackPanel>

						<StackPanel Grid.Column="2">
							<TextBlock Text="Групп дублей"
									   FontSize="12"
									   Foreground="#6B7280" />
							<TextBlock Text="{Binding DuplicateGroupCount}"
									   FontSize="20"
									   FontWeight="SemiBold"
									   Foreground="#111827" />
						</StackPanel>

						<StackPanel Grid.Column="3">
							<TextBlock Text="Конфликтов"
									   FontSize="12"
									   Foreground="#6B7280" />
							<TextBlock Text="{Binding ConflictCount}"
									   FontSize="20"
									   FontWeight="SemiBold"
									   Foreground="#B91C1C" />
						</StackPanel>

						<StackPanel Grid.Column="4"
									HorizontalAlignment="Right"
									VerticalAlignment="Center">
							<CheckBox Content="Выбрать все"
									  IsThreeState="True"
									  IsChecked="{Binding SelectAllState, Mode=TwoWay}" />
						</StackPanel>
					</Grid>
				</Border>

				<ItemsControl ItemsSource="{Binding Messages}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Background="#FFF7ED"
									BorderBrush="#FED7AA"
									BorderThickness="1"
									CornerRadius="8"
									Padding="10"
									Margin="0,0,0,6">
								<TextBlock Text="{Binding}"
										   TextWrapping="Wrap"
										   Foreground="#9A3412" />
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>

			<Border Grid.Column="1"
					Background="#FFFFFF"
					BorderBrush="#D8DEE8"
					BorderThickness="1"
					CornerRadius="10"
					Padding="14"
					Margin="16,0,0,0"
					MinWidth="430"
					Height="70"
					VerticalAlignment="Top">

				<StackPanel Spacing="6">
					<TextBlock Text="Текущий файл"
							   FontSize="12"
							   Foreground="#6B7280" />

					<TextBlock Text="{Binding LoadedFilePath, TargetNullValue='Файл не выбран'}"
							   FontSize="13"
							   Foreground="#111827"
							   TextTrimming="CharacterEllipsis"
							   TextWrapping="NoWrap" />

				</StackPanel>
			</Border>
		</Grid>

		<!-- Таблица -->
		<Border Grid.Row="2"
				Margin="20,0,20,16"
				Background="#FFFFFF"
				BorderBrush="#D8DEE8"
				BorderThickness="1"
				CornerRadius="10"
				ClipToBounds="True">

			<DataGrid x:Name="RospsGrid"
					  ItemsSource="{Binding Rows}"
					  AutoGenerateColumns="False"
					  CanUserResizeColumns="True"
					  CanUserSortColumns="True"
					  GridLinesVisibility="Horizontal"
					  HeadersVisibility="Column"
					  IsReadOnly="False"
					  RowHeight="30"
					  FontSize="12"
					  BorderThickness="0">

				<DataGrid.Columns>

					<DataGridTemplateColumn Header=""
											Width="48"
											CanUserSort="False">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
											  HorizontalAlignment="Center"
											  VerticalAlignment="Center" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Строка"
											Width="90">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding SourceRowNumber}"
											   VerticalAlignment="Center" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Регион"
											Width="90">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding Region}"
											   VerticalAlignment="Center" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Код"
											Width="100">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding Code}"
											   VerticalAlignment="Center" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Наименование"
											Width="320">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding Name}"
											   VerticalAlignment="Center"
											   TextTrimming="CharacterEllipsis" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Адрес"
											Width="360">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding Address}"
											   VerticalAlignment="Center"
											   TextTrimming="CharacterEllipsis" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Начальник"
											Width="220">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding FsspChiefsFullName}"
											   VerticalAlignment="Center"
											   TextTrimming="CharacterEllipsis" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Телефон"
											Width="160">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding FsspTelephoneNumber}"
											   VerticalAlignment="Center"
											   TextTrimming="CharacterEllipsis" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Телефон поддержки"
											Width="180">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding FsspPhoneOfHelpService}"
											   VerticalAlignment="Center"
											   TextTrimming="CharacterEllipsis" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Телефон поддержки 2"
											Width="190">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding FsspPhoneOfHelpService2}"
											   VerticalAlignment="Center"
											   TextTrimming="CharacterEllipsis" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Режим работы"
											Width="300">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding FsspWorkHours}"
											   VerticalAlignment="Center"
											   TextTrimming="CharacterEllipsis" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTemplateColumn Header="Проблема"
											Width="280">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate x:DataType="models:RospPreviewRow">
								<Border Background="{Binding HasConflict, Converter={StaticResource ConflictBackgroundBrushConverter}}"
										Padding="8,0">
									<TextBlock Text="{Binding ValidationError}"
											   VerticalAlignment="Center"
											   Foreground="#B91C1C"
											   TextTrimming="CharacterEllipsis" />
								</Border>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

				</DataGrid.Columns>
			</DataGrid>
		</Border>

		<!-- Нижняя строка состояния -->
		<Border Grid.Row="3"
				Background="#FFFFFF"
				BorderBrush="#D8DEE8"
				BorderThickness="0,1,0,0"
				Padding="20,10">

			<Grid ColumnDefinitions="*,Auto">
				<TextBlock Text="{Binding Status}"
						   VerticalAlignment="Center"
						   Foreground="#374151"
						   TextTrimming="CharacterEllipsis" />

				<TextBlock Grid.Column="1"
						   Text="SQL формируется только по выбранным строкам без конфликтов по коду."
						   VerticalAlignment="Center"
						   Foreground="#6B7280" />
			</Grid>
		</Border>
	</Grid>
</Window>